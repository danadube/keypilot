# Database (Supabase PostgreSQL)
# Runtime (Vercel / app): Transaction pooler :6543 — NEVER Session pooler for DATABASE_URL
#   (Session mode causes FATAL: MaxClientsInSessionMode on serverless.)
# Example: ...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=
# Prisma migrate / db push: direct host db.<project-ref>.supabase.co:5432 (see docs/SETUP.md)
DIRECT_URL=
# Vercel only: set to 1 to skip prisma migrate deploy during build if P3009 blocks deploy (see docs/platform/database-migrations.md)
# SKIP_PRISMA_MIGRATE_ON_BUILD=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=

# Google OAuth (Calendar, Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend) - optional, for follow-up draft sending
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Property lookup - RentCast (by address), 50 free calls/month
RENTCAST_API_KEY=

# Property lookup - MLS (by MLS number), if your board provides an API
MLS_LOOKUP_API_URL=
MLS_LOOKUP_API_KEY=

# Supabase Storage (for property photos)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI (OpenAI) - optional, for email summaries, classification, task suggestions
OPENAI_API_KEY=
