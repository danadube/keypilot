generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductTier {
  OPEN_HOUSE
  FULL_CRM
}

model User {
  id           String      @id @default(uuid())
  clerkId      String      @unique
  name         String
  email        String      @unique
  role         String      @default("agent")
  productTier  ProductTier @default(OPEN_HOUSE)
  /** Per-module access: { "showing-hq": true, "client-keep": false }. Null = defaults (showing-hq enabled). */
  moduleAccess Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  properties        Property[]
  openHouses        OpenHouse[]
  sellerReports     SellerReport[]
  assignedContacts  Contact[]
  tags              Tag[]
  followUpReminders FollowUpReminder[]
  deals             Deal[]
  connections       Connection[]
  usageEvents       UsageEvent[]
  profile           UserProfile?

  @@index([clerkId])
  @@map("users")
}

/** Optional agent branding for sign-in pages, follow-ups, reports. Reusable across modules. */
model UserProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  displayName        String?
  brokerageName      String?
  headshotUrl        String?
  logoUrl            String?
  phone              String?
  email              String?
  brandPrimaryColor  String?
  brandSecondaryColor String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Property {
  id              String    @id @default(uuid())
  mlsNumber       String?   @unique
  address1        String
  address2        String?
  city            String
  state           String
  zip             String
  listingPrice    Decimal?  @db.Decimal(12, 2)
  imageUrl        String?
  notes           String?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdByUser User        @relation(fields: [createdByUserId], references: [id])
  openHouses    OpenHouse[]
  activities    Activity[]
  deals         Deal[]

  @@index([createdByUserId, deletedAt])
  @@index([city, state])
  @@index([zip])
  @@map("properties")
}

model Contact {
  id                 String         @id @default(uuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  hasAgent           Boolean?
  timeline           String?
  notes              String?
  source             String         @default("ShowingsHQ")
  status             ContactStatus? @default(LEAD)
  assignedToUserId   String?
  googleResourceName String?        @unique
  googleEtag         String?
  externalSource     String?
  externalSourceId   String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  assignedToUser    User?              @relation(fields: [assignedToUserId], references: [id])
  openHouseVisits   OpenHouseVisitor[]
  activities        Activity[]
  followUpDrafts    FollowUpDraft[]
  contactTags       ContactTag[]
  followUpReminders FollowUpReminder[]
  deals             Deal[]

  @@index([email])
  @@index([phone])
  @@index([source, createdAt, deletedAt])
  @@index([status])
  @@index([assignedToUserId])
  @@map("contacts")
}

enum ContactStatus {
  LEAD
  CONTACTED
  NURTURING
  READY
  LOST
}

model OpenHouse {
  id         String          @id @default(uuid())
  propertyId String
  hostUserId String
  title      String
  startAt    DateTime
  endAt      DateTime
  agentName  String?
  agentEmail String?
  agentPhone String?
  notes      String?
  flyerUrl   String?
  qrSlug     String          @unique
  status     OpenHouseStatus @default(SCHEDULED)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  property      Property           @relation(fields: [propertyId], references: [id])
  hostUser      User               @relation(fields: [hostUserId], references: [id])
  visitors      OpenHouseVisitor[]
  activities    Activity[]
  drafts        FollowUpDraft[]
  sellerReports SellerReport[]

  @@index([hostUserId, status, startAt])
  @@index([propertyId])
  @@map("open_houses")
}

enum OpenHouseStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

model OpenHouseVisitor {
  id              String            @id @default(uuid())
  openHouseId     String
  contactId       String
  signInMethod    SignInMethod
  submittedAt     DateTime
  rawResponseJson Json?
  leadStatus      VisitorLeadStatus  @default(NEW)
  createdAt       DateTime          @default(now())

  openHouse OpenHouse @relation(fields: [openHouseId], references: [id])
  contact   Contact   @relation(fields: [contactId], references: [id])

  @@index([openHouseId])
  @@index([contactId])
  @@map("open_house_visitors")
}

enum VisitorLeadStatus {
  NEW
  INTERESTED
  HOT_BUYER
  SELLER_LEAD
  NEIGHBOR
  ARCHIVED
}

enum SignInMethod {
  TABLET
  QR
  MANUAL
}

model Activity {
  id           String       @id @default(uuid())
  contactId    String?
  propertyId   String?
  openHouseId  String?
  activityType ActivityType
  body         String
  occurredAt   DateTime
  createdAt    DateTime     @default(now())

  contact   Contact?   @relation(fields: [contactId], references: [id])
  property  Property?  @relation(fields: [propertyId], references: [id])
  openHouse OpenHouse? @relation(fields: [openHouseId], references: [id])

  @@index([contactId])
  @@index([propertyId])
  @@index([openHouseId])
  @@index([occurredAt])
  @@map("activities")
}

enum ActivityType {
  OPEN_HOUSE_CREATED
  VISITOR_SIGNED_IN
  FOLLOW_UP_DRAFT_CREATED
  EMAIL_SENT
  NOTE_ADDED
  CALL_LOGGED
  EMAIL_LOGGED
  SELLER_REPORT_GENERATED
}

model FollowUpDraft {
  id          String         @id @default(uuid())
  contactId   String
  openHouseId String
  subject     String
  body        String         @db.Text
  status      FollowUpStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  contact   Contact   @relation(fields: [contactId], references: [id])
  openHouse OpenHouse @relation(fields: [openHouseId], references: [id])

  @@index([contactId])
  @@index([openHouseId])
  @@index([status])
  @@map("follow_up_drafts")
}

enum FollowUpStatus {
  DRAFT
  REVIEWED
  SENT_MANUAL
  ARCHIVED
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  contactTags ContactTag[]

  @@unique([name, userId])
  @@index([userId])
  @@map("tags")
}

model ContactTag {
  id        String   @id @default(uuid())
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
  @@map("contact_tags")
}

model FollowUpReminder {
  id        String         @id @default(uuid())
  contactId String
  userId    String
  dueAt     DateTime
  body      String         @db.Text
  status    ReminderStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@index([userId])
  @@index([dueAt, status])
  @@map("follow_up_reminders")
}

enum ReminderStatus {
  PENDING
  DONE
  DISMISSED
}

model Deal {
  id         String     @id @default(uuid())
  contactId  String
  propertyId String
  userId     String
  status     DealStatus @default(INTERESTED)
  notes      String?    @db.Text
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([contactId])
  @@index([propertyId])
  @@index([status])
  @@map("deals")
}

enum DealStatus {
  INTERESTED
  SHOWING
  OFFER
  NEGOTIATION
  UNDER_CONTRACT
  CLOSED
  LOST
}

model SellerReport {
  id                String   @id @default(uuid())
  openHouseId       String
  generatedByUserId String
  reportJson        Json
  createdAt         DateTime @default(now())

  openHouse       OpenHouse @relation(fields: [openHouseId], references: [id])
  generatedByUser User      @relation(fields: [generatedByUserId], references: [id])

  @@index([openHouseId])
  @@index([generatedByUserId])
  @@map("seller_reports")
}

model Connection {
  id                      String             @id @default(uuid())
  userId                  String
  provider                ConnectionProvider
  service                 ConnectionService
  accountEmail            String? // Set after OAuth; null for pending
  accountLabel            String?
  status                  ConnectionStatus   @default(DISCONNECTED)
  scopes                  Json?
  isDefault               Boolean            @default(false)
  isEnabled               Boolean            @default(true)
  enabledForAi            Boolean            @default(true)
  enabledForCalendar      Boolean            @default(true)
  enabledForPriorityInbox Boolean            @default(true)
  lastSyncAt              DateTime?
  connectedAt             DateTime?
  syncPreferences         Json?
  errorMessage            String?
  // OAuth tokens (encrypted at rest via DB; avoid logging)
  accessToken             String?
  refreshToken            String?
  tokenExpiresAt          DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, service, accountEmail])
  @@index([userId])
  @@index([userId, provider])
  @@map("connections")
}

enum ConnectionProvider {
  GOOGLE
  MICROSOFT
  APPLE
}

enum ConnectionService {
  GMAIL
  GOOGLE_CALENDAR
  OUTLOOK_MAIL
  OUTLOOK_CALENDAR
  APPLE_MAIL
  APPLE_CALENDAR
  APPLE_CONTACTS
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTED
  PENDING
  ERROR
}

/** Lightweight usage events for ShowingHQ beta analytics. */
model UsageEvent {
  id        String   @id @default(uuid())
  userId    String
  eventName String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
  @@map("usage_events")
}
