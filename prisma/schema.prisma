generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductTier {
  OPEN_HOUSE
  FULL_CRM
}

model User {
  id           String      @id @default(uuid())
  clerkId      String      @unique
  name         String
  email        String      @unique
  role         String      @default("agent")
  productTier  ProductTier @default(OPEN_HOUSE)
  /**
   * Per-module access: { "showing-hq": true, "client-keep": false }. Null = defaults (showing-hq enabled).
   */
  moduleAccess Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  properties                Property[]
  openHouses                OpenHouse[]
  openHousesAsListingAgent  OpenHouse[]                @relation("OpenHouseListingAgent")
  openHousesAsHostAgent     OpenHouse[]                @relation("OpenHouseHostAgent")
  showings                  Showing[]
  feedbackRequests          FeedbackRequest[]
  sellerReports             SellerReport[]
  assignedContacts          Contact[]
  tags                      Tag[]
  followUpReminders         FollowUpReminder[]
  followUps                 FollowUp[]
  deals                     Deal[]
  connections               Connection[]
  usageEvents               UsageEvent[]
  profile                   UserProfile?
  openHouseHostRoles        OpenHouseHost[]
  hostInvitesSent           OpenHouseHostInvite[]
  transactions              Transaction[]
  transactionImportSessions TransactionImportSession[]
  commissions               Commission[]
  supraQueueItems           SupraQueueItem[]
  supraQueueReviewed        SupraQueueItem[]           @relation("SupraQueueReviewedBy")
  supraGmailImportSettings  SupraGmailImportSettings?
  userActivities            UserActivity[]
  activityTemplates         ActivityTemplate[]
  farmTerritories           FarmTerritory[]
  farmAreas                 FarmArea[]
  contactFarmMemberships    ContactFarmMembership[]
  tasks                     Task[]

  @@index([clerkId])
  @@map("users")
}

/**
 * Optional agent branding for sign-in pages, follow-ups, reports. Reusable across modules.
 */
model UserProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  displayName         String?
  brokerageName       String?
  headshotUrl         String?
  logoUrl             String?
  phone               String?
  email               String?
  brandPrimaryColor   String?
  brandSecondaryColor String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Property {
  id              String    @id @default(uuid())
  mlsNumber       String?   @unique
  address1        String
  address2        String?
  city            String
  state           String
  zip             String
  listingPrice    Decimal?  @db.Decimal(12, 2)
  imageUrl        String?
  notes           String?
  flyerUrl        String?
  flyerFilename   String?
  flyerUploadedAt DateTime?
  flyerEnabled    Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdByUser     User              @relation(fields: [createdByUserId], references: [id])
  openHouses        OpenHouse[]
  showings          Showing[]
  feedbackRequests  FeedbackRequest[]
  activities        Activity[]
  deals             Deal[]
  transactions      Transaction[]
  supraQueueMatches SupraQueueItem[]  @relation("SupraQueueMatchedProperty")
  userActivities    UserActivity[]
  tasks             Task[]

  @@index([createdByUserId, deletedAt])
  @@index([city, state])
  @@index([zip])
  @@map("properties")
}

model Contact {
  id                 String         @id @default(uuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  hasAgent           Boolean?
  timeline           String?
  notes              String?
  source             String         @default("ShowingsHQ")
  status             ContactStatus? @default(LEAD)
  assignedToUserId   String?
  googleResourceName String?        @unique
  googleEtag         String?
  externalSource     String?
  externalSourceId   String?
  /** Optional mailing address for exports (FarmTrackr labels, mailings). Editable on the contact record. */
  mailingStreet1     String?
  mailingStreet2     String?
  mailingCity        String?
  mailingState       String?
  mailingZip         String?
  /** Property / site (situs) address for farming; distinct from mailing. */
  siteStreet1        String?
  siteStreet2        String?
  siteCity           String?
  siteState          String?
  siteZip            String?
  email2             String?
  email3             String?
  email4             String?
  phone2             String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  assignedToUser    User?              @relation(fields: [assignedToUserId], references: [id])
  openHouseVisits   OpenHouseVisitor[]
  activities        Activity[]
  followUpDrafts    FollowUpDraft[]
  contactTags       ContactTag[]
  followUpReminders FollowUpReminder[]
  followUps         FollowUp[]
  deals             Deal[]
  userActivities    UserActivity[]
  farmMemberships   ContactFarmMembership[]
  tasks             Task[]

  @@index([email])
  @@index([email2])
  @@index([phone])
  @@index([phone2])
  @@index([source, createdAt, deletedAt])
  @@index([status])
  @@index([assignedToUserId])
  @@map("contacts")
}

enum ContactStatus {
  FARM
  LEAD
  CONTACTED
  NURTURING
  READY
  LOST
}

enum ContactFarmMembershipStatus {
  ACTIVE
  ARCHIVED

  @@map("FarmMembershipStatus")
}

model FarmTerritory {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  areas FarmArea[]

  @@index([userId, deletedAt])
  @@map("farm_territories")
}

model FarmArea {
  id          String   @id @default(uuid())
  userId      String
  territoryId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  territory   FarmTerritory         @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  memberships ContactFarmMembership[]

  @@index([userId, deletedAt])
  @@index([territoryId, deletedAt])
  @@map("farm_areas")
}

model ContactFarmMembership {
  id         String                      @id @default(uuid())
  userId     String
  contactId  String
  farmAreaId String
  status     ContactFarmMembershipStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt
  archivedAt DateTime?

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  farmArea FarmArea @relation(fields: [farmAreaId], references: [id], onDelete: Cascade)

  @@unique([contactId, farmAreaId])
  @@index([userId, status])
  @@index([contactId, status])
  @@index([farmAreaId, status])
  @@map("contact_farm_memberships")
}

model OpenHouse {
  id                    String          @id @default(uuid())
  propertyId            String
  hostUserId            String
  /**
   * Listing agent (property owner). Null = use hostUserId for backward compat.
   */
  listingAgentId        String?
  /**
   * Host agent (sitting the OH). Null = same as listing agent.
   */
  hostAgentId           String?
  title                 String
  startAt               DateTime
  endAt                 DateTime
  agentName             String?
  agentEmail            String?
  agentPhone            String?
  notes                 String?
  flyerUrl              String? // legacy / direct OH flyer
  flyerOverrideUrl      String? // event-specific override (broker open, price reduction)
  flyerOverrideFilename String?
  qrSlug                String          @unique
  status                OpenHouseStatus @default(SCHEDULED)
  trafficLevel          String?
  feedbackTags          Json?
  hostNotes             String?         @db.Text
  /**
   * User-confirmed prep items not inferrable from other columns, e.g. { "hostConfirmed": true, "signsMaterialsReady": true }
   */
  prepChecklistFlags    Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?

  property      Property              @relation(fields: [propertyId], references: [id])
  hostUser      User                  @relation(fields: [hostUserId], references: [id])
  listingAgent  User?                 @relation("OpenHouseListingAgent", fields: [listingAgentId], references: [id])
  hostAgent     User?                 @relation("OpenHouseHostAgent", fields: [hostAgentId], references: [id])
  hosts         OpenHouseHost[]
  hostInvites   OpenHouseHostInvite[]
  visitors      OpenHouseVisitor[]
  activities    Activity[]
  drafts        FollowUpDraft[]
  sellerReports SellerReport[]

  @@index([hostUserId, status, startAt])
  @@index([listingAgentId])
  @@index([hostAgentId])
  @@index([propertyId])
  @@map("open_houses")
}

/**
 * Multi-host support: listing agent (canonical owner), host agents, assistants.
 */
model OpenHouseHost {
  id          String            @id @default(uuid())
  openHouseId String
  userId      String
  role        OpenHouseHostRole

  openHouse OpenHouse @relation(fields: [openHouseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([openHouseId, userId])
  @@index([openHouseId])
  @@index([userId])
  @@map("open_house_hosts")
}

enum OpenHouseHostRole {
  LISTING_AGENT
  HOST_AGENT
  ASSISTANT
}

/**
 * Invite sent by listing agent to add a host. Email with secure token link.
 */
model OpenHouseHostInvite {
  id             String            @id @default(uuid())
  openHouseId    String
  email          String
  role           OpenHouseHostRole @default(HOST_AGENT)
  token          String            @unique
  expiresAt      DateTime
  /**
   * When the token link stops working. Falls back to expiresAt if null (legacy).
   */
  tokenExpiresAt DateTime?
  acceptedAt     DateTime?
  invitedById    String
  createdAt      DateTime          @default(now())

  openHouse OpenHouse @relation(fields: [openHouseId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([openHouseId])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@index([tokenExpiresAt])
  @@map("open_house_host_invites")
}

enum OpenHouseStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

model OpenHouseVisitor {
  id                 String                @id @default(uuid())
  openHouseId        String
  contactId          String
  signInMethod       SignInMethod
  submittedAt        DateTime
  rawResponseJson    Json?
  leadStatus         VisitorLeadStatus     @default(NEW)
  interestLevel      VisitorInterestLevel?
  visitorNotes       String?               @db.Text
  visitorTags        Json?
  flyerEmailSentAt   DateTime?
  flyerEmailStatus   FlyerEmailStatus?
  flyerLinkToken     String?               @unique
  flyerLinkClickedAt DateTime?
  flyerRedirectUrl   String? // PDF URL for /flyer/[token] redirect
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @default(now()) @updatedAt

  openHouse      OpenHouse       @relation(fields: [openHouseId], references: [id])
  contact        Contact         @relation(fields: [contactId], references: [id])
  followUpDrafts FollowUpDraft[]

  @@index([openHouseId])
  @@index([contactId])
  @@index([flyerLinkToken])
  @@map("open_house_visitors")
}

enum FlyerEmailStatus {
  SENT
  FAILED
  UNAVAILABLE
}

enum VisitorInterestLevel {
  VERY_INTERESTED
  MAYBE_INTERESTED
  JUST_BROWSING
}

enum VisitorLeadStatus {
  NEW
  INTERESTED
  HOT_BUYER
  SELLER_LEAD
  NEIGHBOR
  ARCHIVED
}

enum SignInMethod {
  TABLET
  QR
  MANUAL
}

/**
 * Single scheduled private showing (distinct from OpenHouse). Source: manual entry or Supra scrape.
 */
model Showing {
  id                          String        @id @default(uuid())
  propertyId                  String
  hostUserId                  String
  scheduledAt                 DateTime
  buyerAgentName              String?
  buyerAgentEmail             String?
  buyerName                   String?
  notes                       String?       @db.Text
  feedbackRequired            Boolean       @default(false)
  source                      ShowingSource @default(MANUAL)
  scrapeStatus                String? // e.g. PARSED, MATCHED, UNMATCHED
  feedbackRequestStatus       String? // e.g. PENDING, SENT, RECEIVED
  /**
   * Buyer-agent follow-up email draft (e.g. after Supra apply). Gmail/API send is not wired in v1.
   */
  feedbackDraftSubject        String?
  feedbackDraftBody           String?       @db.Text
  feedbackDraftGeneratedAt    DateTime?
  /**
   * When the host marked the buyer-agent feedback email as sent from their mail client.
   */
  feedbackEmailSentAt         DateTime?
  /**
   * User-confirmed prep when feedback workflow needs explicit confirmation, e.g. { "followUpPathReady": true }
   */
  prepChecklistFlags          Json?
  /**
   * Raw plain-text body of buyer-agent email reply (source of truth).
   */
  buyerAgentEmailReplyRaw     String?       @db.Text
  buyerAgentEmailReplyAt      DateTime?
  buyerAgentEmailReplyFrom    String?
  /**
   * Gmail thread id for the buyer-agent feedback email conversation (ingestion only processes this thread).
   */
  feedbackGmailThreadId       String?
  /**
   * RFC Message-ID of the host's sent feedback email (optional; strengthens reply chain).
   */
  feedbackSentRfcMessageId    String?
  /**
   * Gmail message id for idempotent ingestion
   */
  buyerAgentEmailReplyGmailId String?       @unique
  /**
   * Optional rule-based highlights { interestHint?, concerns?, pricingComment?, followUpInterest?, confidence } — never replaces raw
   */
  buyerAgentEmailReplyParsed  Json?
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  deletedAt                   DateTime?

  property          Property          @relation(fields: [propertyId], references: [id])
  hostUser          User              @relation(fields: [hostUserId], references: [id])
  feedbackRequests  FeedbackRequest[]
  supraQueueMatches SupraQueueItem[]  @relation("SupraQueueMatchedShowing")

  @@index([hostUserId])
  @@index([propertyId])
  @@index([scheduledAt])
  @@index([source])
  @@map("showings")
}

/**
 * One per showing when feedback is requested. Public form submits to this.
 */
model FeedbackRequest {
  id            String                @id @default(uuid())
  showingId     String
  propertyId    String
  hostUserId    String
  token         String                @unique
  status        FeedbackRequestStatus @default(PENDING)
  requestedAt   DateTime              @default(now())
  expiresAt     DateTime?
  /**
   * Response: LOVED_IT | LIKED_IT | NEUTRAL | NOT_A_FIT
   */
  interestLevel String?
  /**
   * Response: array of reason keys e.g. ["PRICE", "LAYOUT"]
   */
  reasons       Json?
  note          String?               @db.Text
  respondedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  showing  Showing  @relation(fields: [showingId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id])
  hostUser User     @relation(fields: [hostUserId], references: [id])

  @@index([showingId])
  @@index([propertyId])
  @@index([hostUserId])
  @@index([token])
  @@index([status])
  @@map("feedback_requests")
}

enum FeedbackRequestStatus {
  PENDING
  RESPONDED
  EXPIRED
}

enum ShowingSource {
  MANUAL
  SUPRA_SCRAPE
}

/**
 * Review queue for Supra (and future) email ingests — human confirm before showings/properties change.
 */
enum SupraQueueState {
  INGESTED
  PARSED
  NEEDS_REVIEW
  READY_TO_APPLY
  APPLIED
  FAILED_PARSE
  DISMISSED
  DUPLICATE
}

enum SupraParseConfidence {
  HIGH
  MEDIUM
  LOW
}

enum SupraPropertyMatchStatus {
  UNSET
  NO_MATCH
  MATCHED
  AMBIGUOUS
  POSSIBLE_DUPLICATE
}

enum SupraShowingMatchStatus {
  UNSET
  NO_SHOWING
  MATCHED
  AMBIGUOUS
  POSSIBLE_DUPLICATE
}

enum SupraProposedAction {
  UNKNOWN
  CREATE_SHOWING
  UPDATE_SHOWING
  CREATE_PROPERTY_AND_SHOWING
  DISMISS
  NEEDS_MANUAL_REVIEW
}

model SupraQueueItem {
  id         String @id @default(uuid())
  hostUserId String

  source            String   @default("supra")
  externalMessageId String
  subject           String
  receivedAt        DateTime
  rawBodyText       String   @db.Text
  sender            String?

  parsedAddress1       String?
  parsedCity           String?
  parsedState          String?
  parsedZip            String?
  parsedScheduledAt    DateTime?
  /**
   * Supra end-of-showing: \"that began …\" time — aligns with Showing.scheduledAt for linking
   */
  parsedShowingBeganAt DateTime?
  parsedEventKind      String?
  parsedStatus         String?
  parsedAgentName      String?
  parsedAgentEmail     String?
  parseConfidence      SupraParseConfidence @default(LOW)
  proposedAction       SupraProposedAction  @default(UNKNOWN)

  matchedPropertyId   String?
  matchedShowingId    String?
  propertyMatchStatus SupraPropertyMatchStatus @default(UNSET)
  showingMatchStatus  SupraShowingMatchStatus  @default(UNSET)

  queueState       SupraQueueState @default(INGESTED)
  reviewedAt       DateTime?
  reviewedByUserId String?
  resolutionNotes  String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostUser        User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  matchedProperty Property? @relation("SupraQueueMatchedProperty", fields: [matchedPropertyId], references: [id], onDelete: SetNull)
  matchedShowing  Showing?  @relation("SupraQueueMatchedShowing", fields: [matchedShowingId], references: [id], onDelete: SetNull)
  reviewedBy      User?     @relation("SupraQueueReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([hostUserId, externalMessageId])
  @@index([hostUserId, queueState])
  @@index([hostUserId, receivedAt])
  @@map("supra_queue_items")
}

/**
 * Per-user Supra Gmail import automation metadata (scheduled + manual runs).
 */
model SupraGmailImportSettings {
  id                 String    @id @default(uuid())
  userId             String    @unique
  /**
   * When false, scheduled cron skips this user; manual runs still work.
   */
  automationEnabled  Boolean   @default(true)
  lastRunAt          DateTime?
  lastRunSuccess     Boolean?
  /**
   * "manual" | "scheduled"
   */
  lastRunSource      String?
  lastRunImported    Int?
  lastRunRefreshed   Int?
  lastRunSkipped     Int?
  lastRunScanned     Int?
  lastRunAutoParsed  Int?
  lastRunError       String?   @db.VarChar(1000)
  /**
   * Set while Gmail import is running; cleared when the run finishes. Stale locks are overridden after ~12 minutes if a worker crashes.
   */
  importRunStartedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("supra_gmail_import_settings")
}

model Activity {
  id           String       @id @default(uuid())
  contactId    String?
  propertyId   String?
  openHouseId  String?
  activityType ActivityType
  body         String
  occurredAt   DateTime
  createdAt    DateTime     @default(now())

  contact   Contact?   @relation(fields: [contactId], references: [id])
  property  Property?  @relation(fields: [propertyId], references: [id])
  openHouse OpenHouse? @relation(fields: [openHouseId], references: [id])

  @@index([contactId])
  @@index([propertyId])
  @@index([openHouseId])
  @@index([occurredAt])
  @@map("activities")
}

/**
 * User-owned CRM activities (calls, tasks, follow-ups). Distinct from `Activity` (open-house timeline events).
 */
model UserActivity {
  id          String           @id @default(uuid())
  userId      String
  propertyId  String?
  contactId   String?
  type        UserActivityType
  title       String
  description String?          @db.Text
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  contact  Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  logs     ActivityLog[]

  @@index([userId])
  @@index([propertyId])
  @@index([contactId])
  @@index([userId, dueAt])
  @@index([userId, type])
  @@map("user_activities")
}

enum UserActivityType {
  CALL
  EMAIL
  NOTE
  TASK
  SHOWING
  FOLLOW_UP
}

model ActivityTemplate {
  id                  String           @id @default(uuid())
  userId              String
  name                String
  type                UserActivityType
  titleTemplate       String
  descriptionTemplate String?          @db.Text
  offsetDays          Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@map("activity_templates")
}

model ActivityLog {
  id         String            @id @default(uuid())
  activityId String
  action     ActivityLogAction
  createdAt  DateTime          @default(now())

  activity UserActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([activityId, createdAt])
  @@map("activity_logs")
}

enum ActivityLogAction {
  CREATED
  COMPLETED
  UPDATED
}

enum ActivityType {
  OPEN_HOUSE_CREATED
  VISITOR_SIGNED_IN
  FOLLOW_UP_DRAFT_CREATED
  EMAIL_SENT
  NOTE_ADDED
  CALL_LOGGED
  EMAIL_LOGGED
  SELLER_REPORT_GENERATED
}

model FollowUpDraft {
  id                 String         @id @default(uuid())
  contactId          String
  openHouseId        String
  openHouseVisitorId String? // optional link to the sign-in that generated this draft
  subject            String
  body               String         @db.Text
  status             FollowUpStatus @default(DRAFT)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  contact          Contact           @relation(fields: [contactId], references: [id])
  openHouse        OpenHouse         @relation(fields: [openHouseId], references: [id])
  openHouseVisitor OpenHouseVisitor? @relation(fields: [openHouseVisitorId], references: [id])

  @@index([contactId])
  @@index([openHouseId])
  @@index([openHouseVisitorId])
  @@index([status])
  @@map("follow_up_drafts")
}

enum FollowUpStatus {
  DRAFT
  REVIEWED
  SENT_MANUAL
  ARCHIVED
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  contactTags ContactTag[]

  @@unique([name, userId])
  @@index([userId])
  @@map("tags")
}

model ContactTag {
  id        String   @id @default(uuid())
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
  @@map("contact_tags")
}

model FollowUpReminder {
  id        String         @id @default(uuid())
  contactId String
  userId    String
  dueAt     DateTime
  body      String         @db.Text
  status    ReminderStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@index([userId])
  @@index([dueAt, status])
  @@map("follow_up_reminders")
}

enum ReminderStatus {
  PENDING
  DONE
  DISMISSED
}

/**
 * Agent-owned follow-up tasks (people-centric). `sourceType` + `sourceId` link to OH visitor, event, showing, etc.
 */
model FollowUp {
  id              String               @id @default(uuid())
  createdByUserId String
  contactId       String
  sourceType      FollowUpSourceType
  /**
   * Visitor id, open house id, showing id, feedback request id, or `manual` for MANUAL source.
   */
  sourceId        String
  status          FollowUpTaskStatus   @default(NEW)
  priority        FollowUpTaskPriority @default(MEDIUM)
  title           String
  notes           String?              @db.Text
  dueAt           DateTime
  completedAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([createdByUserId, dueAt, status])
  @@index([createdByUserId, status])
  @@index([contactId])
  @@index([sourceType, sourceId])
  @@map("follow_ups")
}

enum FollowUpSourceType {
  OPEN_HOUSE
  FEEDBACK
  SHOWING
  MANUAL
}

enum FollowUpTaskStatus {
  NEW
  PENDING
  CONTACTED
  NURTURE
  CLOSED
}

enum FollowUpTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  OPEN
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/**
 * TaskPilot — user-owned operational tasks (optional contact link).
 */
model Task {
  id          String        @id @default(uuid())
  userId      String
  title       String
  description String?       @db.Text
  status      TaskStatus    @default(OPEN)
  dueAt       DateTime?
  priority    TaskPriority  @default(MEDIUM)
  contactId   String?
  propertyId  String?
  createdAt   DateTime      @default(now())
  completedAt DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, dueAt])
  @@index([contactId])
  @@index([propertyId])
  @@map("tasks")
}

model Deal {
  id         String     @id @default(uuid())
  contactId  String
  propertyId String
  userId     String
  status     DealStatus @default(INTERESTED)
  notes      String?    @db.Text
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  /**
   * At most one transaction may reference a deal in v1 (see Transaction.dealId @unique).
   */
  linkedTransaction Transaction? @relation("TransactionLinkedDeal")

  @@index([userId])
  @@index([contactId])
  @@index([propertyId])
  @@index([status])
  @@map("deals")
}

enum DealStatus {
  INTERESTED
  SHOWING
  OFFER
  NEGOTIATION
  UNDER_CONTRACT
  CLOSED
  LOST
}

model SellerReport {
  id                String   @id @default(uuid())
  openHouseId       String
  generatedByUserId String
  reportJson        Json
  createdAt         DateTime @default(now())

  openHouse       OpenHouse @relation(fields: [openHouseId], references: [id])
  generatedByUser User      @relation(fields: [generatedByUserId], references: [id])

  @@index([openHouseId])
  @@index([generatedByUserId])
  @@map("seller_reports")
}

model Connection {
  id                      String             @id @default(uuid())
  userId                  String
  provider                ConnectionProvider
  service                 ConnectionService
  accountEmail            String? // Set after OAuth; null for pending
  accountLabel            String?
  status                  ConnectionStatus   @default(DISCONNECTED)
  scopes                  Json?
  isDefault               Boolean            @default(false)
  isEnabled               Boolean            @default(true)
  enabledForAi            Boolean            @default(true)
  enabledForCalendar      Boolean            @default(true)
  enabledForPriorityInbox Boolean            @default(true)
  lastSyncAt              DateTime?
  connectedAt             DateTime?
  syncPreferences         Json?
  errorMessage            String?
  // OAuth tokens (encrypted at rest via DB; avoid logging)
  accessToken             String?
  refreshToken            String?
  tokenExpiresAt          DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, service, accountEmail])
  @@index([userId])
  @@index([userId, provider])
  @@map("connections")
}

enum ConnectionProvider {
  GOOGLE
  MICROSOFT
  APPLE
}

enum ConnectionService {
  GMAIL
  GOOGLE_CALENDAR
  OUTLOOK_MAIL
  OUTLOOK_CALENDAR
  APPLE_MAIL
  APPLE_CALENDAR
  APPLE_CONTACTS
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTED
  PENDING
  ERROR
}

/**
 * Lightweight usage events for ShowingHQ beta analytics.
 */
model UsageEvent {
  id        String   @id @default(uuid())
  userId    String
  eventName String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventName])
  @@index([createdAt])
  @@map("usage_events")
}

// ─── Transactions module (DealForge / FarmTrackr-inspired) ──────────────────
model Transaction {
  id            String            @id @default(uuid())
  propertyId    String
  userId        String
  /**
   * Optional CRM deal (same user, same property). At most one transaction per deal in v1.
   */
  dealId        String?           @unique
  status        TransactionStatus @default(PENDING)
  salePrice     Decimal?          @db.Decimal(12, 2)
  closingDate   DateTime?
  brokerageName String?
  notes         String?           @db.Text
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  property                Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user                    User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal                    Deal?                      @relation("TransactionLinkedDeal", fields: [dealId], references: [id], onDelete: SetNull)
  commissions             Commission[]
  committedImportSessions TransactionImportSession[]
  checklistItems          TransactionChecklistItem[]

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([closingDate])
  @@index([userId, deletedAt])
  @@map("transactions")
}

/** Persisted per-transaction checklist rows (TransactionHQ operational steps). */
model TransactionChecklistItem {
  id            String    @id @default(uuid())
  transactionId String
  title         String
  isComplete    Boolean   @default(false)
  sortOrder     Int       @default(0)
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([transactionId, isComplete])
  @@map("transaction_checklist_items")
}

enum TransactionStatus {
  LEAD
  UNDER_CONTRACT
  IN_ESCROW
  PENDING
  CLOSED
  FALLEN_APART
}

enum TransactionImportStatus {
  PARSED
  REVIEWED
  COMMITTED
  FAILED
}

/**
 * Commission split per transaction.
 */
model Commission {
  id            String   @id @default(uuid())
  transactionId String
  agentId       String?
  role          String // e.g. LISTING_AGENT, BUYER_AGENT, REFERRAL
  amount        Decimal  @db.Decimal(12, 2)
  percent       Decimal? @db.Decimal(5, 2)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  agent       User?       @relation(fields: [agentId], references: [id])

  @@index([transactionId])
  @@index([agentId])
  @@map("commissions")
}

model TransactionImportSession {
  id                     String                  @id @default(uuid())
  userId                 String
  status                 TransactionImportStatus @default(PARSED)
  fileName               String
  mimeType               String
  parsedPayload          Json
  editedPayload          Json?
  detectedBrokerage      String?
  selectedBrokerage      String?
  parserProfile          String                  @default("generic")
  parserProfileVersion   String                  @default("v1")
  brokerageProfile       String?
  parserVersion          String
  confidence             Float
  warnings               Json
  committedTransactionId String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  committedTransaction Transaction? @relation(fields: [committedTransactionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("transaction_import_sessions")
}
